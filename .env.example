# ╔══════════════════════════════════════════════════════════════════╗
# ║  SmartTender AI — Environment Variables                         ║
# ║  Copy this file to .env and fill in values.                     ║
# ║  Lines marked [DEV-SAFE] can be left as-is for local dev.      ║
# ╚══════════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────
# PostgreSQL                                    
# ──────────────────────────────────────────────

# Database superuser password. Change in production! [DEV-SAFE]
POSTGRES_PASSWORD=smarttender_dev

# Database name. [DEV-SAFE]
POSTGRES_DB=smarttender

# Database user. [DEV-SAFE]
POSTGRES_USER=smarttender

# Internal hostname — matches the compose service name. [DEV-SAFE]
POSTGRES_HOST=postgres

# Standard port. [DEV-SAFE]
POSTGRES_PORT=5432

# ──────────────────────────────────────────────
# Redis                                         
# ──────────────────────────────────────────────

# Internal hostname — matches the compose service name. [DEV-SAFE]
REDIS_HOST=redis

# Standard port. [DEV-SAFE]
REDIS_PORT=6379

# ──────────────────────────────────────────────
# Qdrant (Vector Store)                         
# ──────────────────────────────────────────────

# Internal hostname — matches the compose service name. [DEV-SAFE]
QDRANT_HOST=qdrant

# REST API port. [DEV-SAFE]
QDRANT_PORT=6333

# gRPC port — used by some clients for faster upserts. [DEV-SAFE]
QDRANT_GRPC_PORT=6334

# Collection name for document embeddings. [DEV-SAFE]
QDRANT_COLLECTION=tender_docs

# Embedding vector dimension — nomic-embed-text produces 768-dim vectors. [DEV-SAFE]
QDRANT_VECTOR_SIZE=768

# ──────────────────────────────────────────────
# Docker Model Runner (LLM / Embeddings)        
# NOT a compose service — runs as a Docker       
# Desktop daemon. Enable in Docker Desktop       
# Settings → Features → Docker Model Runner.     
# ──────────────────────────────────────────────

# Base URL for OpenAI-compatible API. Reachable from any container. [DEV-SAFE]
MODEL_RUNNER_BASE_URL=http://model-runner.docker.internal/engines/llama.cpp/v1

# Model identifiers — must match what you pulled with `docker model pull`. [DEV-SAFE]
MODEL_LLM=ai/mistral-7b-instruct-q4
MODEL_EMBEDDINGS=ai/nomic-embed-text
MODEL_VISION=ai/llava-7b

# ──────────────────────────────────────────────
# Docling (OCR Microservice)                    
# ──────────────────────────────────────────────

# Internal hostname — matches the compose service name. [DEV-SAFE]
DOCLING_HOST=docling

# Port exposed by the Docling container. [DEV-SAFE]
DOCLING_PORT=8001

# Confidence threshold — pages below this score are sent to llava for vision OCR. [DEV-SAFE]
DOCLING_CONFIDENCE_THRESHOLD=0.7

# ──────────────────────────────────────────────
# n8n (AI Workflow Orchestrator)                
# ──────────────────────────────────────────────

# Basic auth for the n8n web UI. Change in production!
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=smarttender_n8n

# Webhook base URL — n8n needs to know its own URL for webhook triggers.
# In dev, this is the Docker internal URL. [DEV-SAFE]
N8N_WEBHOOK_URL=http://n8n:5678

# Timezone for scheduled workflows. [DEV-SAFE]
N8N_DEFAULT_TIMEZONE=Asia/Kolkata

# ──────────────────────────────────────────────
# FastAPI Backend                               
# ──────────────────────────────────────────────

# The backend constructs a SQLAlchemy URL from the PG vars above.
# This is the full async URL if you need to override it. [DEV-SAFE]
DATABASE_URL=postgresql+asyncpg://smarttender:smarttender_dev@postgres:5432/smarttender

# CORS origins — comma-separated. Add your Cloudflare Pages URL in prod.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload directory inside the container (mounted as a volume). [DEV-SAFE]
UPLOAD_DIR=/app/uploads

# Report output directory inside the container. [DEV-SAFE]
REPORT_DIR=/app/reports

# Log level. [DEV-SAFE]
LOG_LEVEL=INFO

# n8n webhook base URL — backend uses this to trigger n8n workflows. [DEV-SAFE]
N8N_WEBHOOK_BASE_URL=http://n8n:5678/webhook

# ──────────────────────────────────────────────
# Frontend (build-time only)                    
# ──────────────────────────────────────────────

# API base URL injected at build time. In dev, Vite proxies to backend. [DEV-SAFE]
VITE_API_BASE_URL=http://localhost:8000/api/v1
